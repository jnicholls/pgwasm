-- Error mapping: SQLSTATE + DETAIL (module_id / export_index / wasmtime) + HINT where applicable.
-- Extension is created by tests/pg_regress/sql/setup.sql.
-- pgwasm is disabled (55000): DETAIL lists module_id=none until a call site supplies context.
SET pgwasm.enabled = off;
DO $$
DECLARE
    _detail text;
BEGIN
    PERFORM pgwasm.pgwasm_load(
        'errors_disabled',
        json_build_object(
            'bytes',
            '0061736d0100000001070160027f7f017f030201000707010361646400000a09010700200020016a0b'
        ),
        NULL
    );
    RAISE EXCEPTION 'expected load to fail when pgwasm.enabled is off';
EXCEPTION
    WHEN OTHERS THEN
        GET STACKED DIAGNOSTICS _detail = PG_EXCEPTION_DETAIL;
        IF SQLSTATE IS DISTINCT FROM '55000' THEN
            RAISE EXCEPTION 'disabled: expected SQLSTATE 55000, got %', SQLSTATE;
        END IF;
        IF _detail IS NULL OR position('module_id=none' in _detail) = 0 THEN
            RAISE EXCEPTION 'disabled: expected module_id=none in DETAIL, got: %', _detail;
        END IF;
        IF position('wasmtime=43.0.0' in _detail) = 0 THEN
            RAISE EXCEPTION 'disabled: expected wasmtime version in DETAIL, got: %', _detail;
        END IF;
END
$$;
RESET pgwasm.enabled;
-- Invalid configuration (22023): empty module name.
DO $$
DECLARE
    _detail text;
BEGIN
    PERFORM pgwasm.pgwasm_load(
        '',
        json_build_object('bytes', '0061736d01000000'),
        NULL
    );
    RAISE EXCEPTION 'expected load to fail for empty module name';
EXCEPTION
    WHEN OTHERS THEN
        GET STACKED DIAGNOSTICS _detail = PG_EXCEPTION_DETAIL;
        IF SQLSTATE IS DISTINCT FROM '22023' THEN
            RAISE EXCEPTION 'empty name: expected SQLSTATE 22023, got %', SQLSTATE;
        END IF;
        IF _detail IS NULL OR position('module_id=none' in _detail) = 0 THEN
            RAISE EXCEPTION 'empty name: expected module_id=none in DETAIL, got: %', _detail;
        END IF;
END
$$;
-- Permission denied (42501): file load without role / GUC — DETAIL + HINT.
DO $$
DECLARE
    _detail text;
    _hint text;
BEGIN
    PERFORM pgwasm.pgwasm_load(
        'errors_perm',
        json_build_object('path', '/no/such/pgwasm_errors_path.wasm'),
        NULL
    );
    RAISE EXCEPTION 'expected load from path to be denied';
EXCEPTION
    WHEN insufficient_privilege THEN
        GET STACKED DIAGNOSTICS _detail = PG_EXCEPTION_DETAIL;
        GET STACKED DIAGNOSTICS _hint = PG_EXCEPTION_HINT;
        IF _detail IS NULL OR position('module_id=none' in _detail) = 0 THEN
            RAISE EXCEPTION 'perm: expected module_id=none in DETAIL, got: %', _detail;
        END IF;
        IF _hint IS NULL OR position('pgwasm.allow_load_from_file' in _hint) = 0 THEN
            RAISE EXCEPTION 'perm: expected policy GUC hint, got: %', _hint;
        END IF;
    WHEN OTHERS THEN
        RAISE EXCEPTION 'expected insufficient_privilege, got %: %', SQLSTATE, SQLERRM;
END
$$;
-- Undefined object (42704): unload missing module.
DO $$
DECLARE
    _detail text;
BEGIN
    PERFORM pgwasm.pgwasm_unload('errors_no_such_module_xyz', false);
    RAISE EXCEPTION 'expected unload to fail for missing module';
EXCEPTION
    WHEN undefined_object THEN
        GET STACKED DIAGNOSTICS _detail = PG_EXCEPTION_DETAIL;
        IF _detail IS NULL OR position('module_id=none' in _detail) = 0 THEN
            RAISE EXCEPTION 'notfound: expected module_id=none in DETAIL, got: %', _detail;
        END IF;
    WHEN OTHERS THEN
        RAISE EXCEPTION 'expected undefined_object, got %: %', SQLSTATE, SQLERRM;
END
$$;
-- Program limit exceeded (54000): module larger than pgwasm.max_module_bytes.
SET pgwasm.max_module_bytes = 1;
DO $$
DECLARE
    _detail text;
BEGIN
    PERFORM pgwasm.pgwasm_load(
        'errors_limit',
        json_build_object('bytes', '010203'),
        NULL
    );
    RAISE EXCEPTION 'expected load to fail when max_module_bytes is too small';
EXCEPTION
    WHEN program_limit_exceeded THEN
        GET STACKED DIAGNOSTICS _detail = PG_EXCEPTION_DETAIL;
        IF _detail IS NULL OR position('module_id=none' in _detail) = 0 THEN
            RAISE EXCEPTION 'limit: expected module_id=none in DETAIL, got: %', _detail;
        END IF;
    WHEN OTHERS THEN
        RAISE EXCEPTION 'expected program_limit_exceeded, got %: %', SQLSTATE, SQLERRM;
END
$$;
RESET pgwasm.max_module_bytes;
-- Feature not supported (0A000): valid core module with no supported scalar exports.
DO $$
DECLARE
    _detail text;
BEGIN
    PERFORM pgwasm.pgwasm_load(
        'errors_core_unsupported',
        json_build_object('bytes', '0061736d01000000'),
        json_build_object('abi', 'core')
    );
    RAISE EXCEPTION 'expected core-only load to be unsupported in this configuration';
EXCEPTION
    WHEN feature_not_supported THEN
        GET STACKED DIAGNOSTICS _detail = PG_EXCEPTION_DETAIL;
        IF _detail IS NULL OR position('module_id=none' in _detail) = 0 THEN
            RAISE EXCEPTION 'unsupported: expected module_id=none in DETAIL, got: %', _detail;
        END IF;
    WHEN OTHERS THEN
        RAISE EXCEPTION 'expected feature_not_supported, got %: %', SQLSTATE, SQLERRM;
END
$$;
-- After a successful load, duplicate load reports the existing module_id in DETAIL.
