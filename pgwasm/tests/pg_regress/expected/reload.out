-- Record field addition: safe ALTER TYPE transition; pg_type OID preserved.
-- Re-run this suite on a reused regress DB with: `cargo pgrx regress --resetdb reload`
-- (v2 adds a composite field; PostgreSQL cannot remove it, so v1 `load` cannot run again in the same DB.)
DO $rr_record_reset$
BEGIN
    IF EXISTS (SELECT 1 FROM pgwasm.modules WHERE name = 'reload_record_fixture') THEN
        BEGIN
            PERFORM pgwasm.pgwasm_unload('reload_record_fixture', true);
        EXCEPTION
            WHEN OTHERS THEN
                BEGIN
                    PERFORM pgwasm.pgwasm_test_force_cleanup_stuck_module('reload_record_fixture', true);
                EXCEPTION
                    WHEN OTHERS THEN
                        NULL;
                END;
        END;
    END IF;
END;
$rr_record_reset$;
