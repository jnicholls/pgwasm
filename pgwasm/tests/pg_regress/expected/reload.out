-- pgwasm.pgwasm_reload: OID-preserving reload, breaking-change gate, transaction rollback.
-- Extension is created by tests/pg_regress/sql/setup.sql.
-- WASM fixtures: wit-bindgen guests built for wasm32-wasip2 (component binaries).
-- Best-effort cleanup so `cargo pgrx regress reload` is repeatable on a reused DB.
-- If a prior `unload` failed mid-flight, `test_force_cleanup_stuck_module` (superuser) drops stale catalog rows.
DO $rr_reload_init$
DECLARE
    fixture text;
BEGIN
    FOREACH fixture IN ARRAY ARRAY[
        'reload_regress_fixture',
        'reload_record_fixture',
        'reload_rename_fixture'
    ]
    LOOP
        BEGIN
            IF EXISTS (SELECT 1 FROM pgwasm.modules WHERE name = fixture) THEN
                PERFORM pgwasm.pgwasm_unload(fixture, true);
            END IF;
        EXCEPTION
            WHEN OTHERS THEN
                BEGIN
                    PERFORM pgwasm.pgwasm_test_force_cleanup_stuck_module(fixture, true);
                EXCEPTION
                    WHEN OTHERS THEN
                        NULL;
                END;
        END;
    END LOOP;
END;
$rr_reload_init$;
-- Baseline: tiny component (same as load.sql regress).
SELECT pgwasm.pgwasm_load(
    'reload_regress_fixture',
    json_build_object(
        'bytes',
        to_json(
            ARRAY[
                0, 97, 115, 109, 13, 0, 1, 0, 1, 85, 0, 97, 115, 109, 1, 0, 0, 0, 1, 5, 1, 96, 0, 1, 127, 3, 2, 1, 0, 7, 7, 1, 3, 97, 100, 100, 0, 0, 10, 6, 1, 4, 0, 65, 42, 11, 0, 47, 9, 112, 114, 111, 100, 117, 99, 101, 114, 115, 1, 12, 112, 114, 111, 99, 101, 115, 115, 101, 100, 45, 98, 121, 1, 13, 119, 105, 116, 45, 99, 111, 109, 112, 111, 110, 101, 110, 116, 7, 48, 46, 50, 52, 55, 46, 48, 2, 4, 1, 0, 0, 0, 7, 5, 1, 64, 0, 0, 122, 6, 9, 1, 0, 0, 1, 0, 3, 97, 100, 100, 8, 6, 1, 0, 0, 0, 0, 0, 11, 9, 1, 0, 3, 97, 100, 100, 1, 0, 0, 0, 61, 14, 99, 111, 109, 112, 111, 110, 101, 110, 116, 45, 110, 97, 109, 101, 1, 8, 0, 0, 1, 0, 3, 97, 100, 100, 1, 9, 0, 17, 1, 0, 4, 109, 97, 105, 110, 1, 9, 0, 18, 1, 0, 4, 109, 97, 105, 110, 1, 12, 1, 2, 0, 3, 97, 100, 100, 1, 3, 97, 100, 100, 0, 47, 9, 112, 114, 111, 100, 117, 99, 101, 114, 115, 1, 12, 112, 114, 111, 99, 101, 115, 115, 101, 100, 45, 98, 121, 1, 13, 119, 105, 116, 45, 99, 111, 109, 112, 111, 110, 101, 110, 116, 7, 48, 46, 50, 52, 55, 46, 48
            ]::int[]
        )
    ),
    NULL
) AS loaded;
