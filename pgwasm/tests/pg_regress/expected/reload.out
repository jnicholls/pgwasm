(1 row)

SELECT
    (SELECT MIN(b.pg_type_oid) FROM rr_record_pair_attrs_before b) =
    (SELECT MIN(wt.pg_type_oid)
     FROM pgwasm.wit_types wt
     JOIN pgwasm.modules m ON m.module_id = wt.module_id
     WHERE m.name = 'reload_record_fixture' AND wt.wit_name LIKE '%/pair')
        AS record_pair_pg_type_oid_preserved,
    (SELECT MIN(b.wit_name) FROM rr_record_pair_attrs_before b) =
    (SELECT MIN(wt.wit_name)
     FROM pgwasm.wit_types wt
     JOIN pgwasm.modules m ON m.module_id = wt.module_id
     WHERE m.name = 'reload_record_fixture' AND wt.wit_name LIKE '%/pair')
        AS record_pair_wit_name_preserved,
    (SELECT array_agg(attname ORDER BY attnum)
     FROM (
         SELECT a.attname, a.attnum
         FROM pgwasm.wit_types wt
         JOIN pgwasm.modules m ON m.module_id = wt.module_id
         JOIN pg_catalog.pg_type t ON t.oid = wt.pg_type_oid
         JOIN pg_catalog.pg_attribute a ON a.attrelid = t.typrelid AND a.attnum > 0 AND NOT a.attisdropped
         WHERE m.name = 'reload_record_fixture' AND wt.wit_name LIKE '%/pair'
     ) s)
        = ARRAY['x'::name, 'y'::name]
        AS record_v2_pair_attrs;
