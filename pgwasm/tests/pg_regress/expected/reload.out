SELECT COUNT(*) = 1 AND bool_and(wasm_name = 'second') AS rename_one_second_export_after_replace
FROM pgwasm.exports e
JOIN pgwasm.modules m ON m.module_id = e.module_id
WHERE m.name = 'reload_rename_fixture';
 rename_one_second_export_after_replace 
