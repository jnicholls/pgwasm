-- Baseline OIDs/catalog ids depend on cluster state; compare relative to this snapshot.
CREATE TEMP TABLE rr_regress_add_baseline AS
SELECT e.export_id, e.fn_oid, m.generation AS gen
FROM pgwasm.exports e
JOIN pgwasm.modules m ON m.module_id = e.module_id
WHERE m.name = 'reload_regress_fixture';
SELECT COUNT(*) = 1 AS baseline_one_export
FROM rr_regress_add_baseline;
