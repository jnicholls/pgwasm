CREATE TEMP TABLE rr_rename_export_baseline AS
SELECT e.export_id, e.wasm_name, e.fn_oid
FROM pgwasm.exports e
JOIN pgwasm.modules m ON m.module_id = e.module_id
WHERE m.name = 'reload_rename_fixture';
SELECT COUNT(*) = 1 AND bool_and(wasm_name = 'first') AS rename_baseline_one_first_export
FROM rr_rename_export_baseline;
